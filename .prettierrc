{
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "<THIRD_PARTY_MODULES>",
    "^#config(/.*)?$",
    "^#i18n(/.*)?$",
    "^#ui(/.*)?$",
    "^#utils(/.*)?$",
    "^#actions(/.*)?$",
    "^getters(/.*)?$",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "semi": false,
  "singleQuote": true,
  "printWidth": 80,
  "trailingComma": "none"
}
